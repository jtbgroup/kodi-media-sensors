/.history

# Ignore all Python bytecode cache directories and files starting with __
**/__*

# ------------------
# HA Configuration
# ------------------

# Ignore everything in the config directory
config/*

# But force Git to track your custom dashboard and its configuration
!config/configuration.yaml
!config/kodi_dashboard.yaml

# Force Git to track the Lovelace resources database file
!config/.storage/lovelace_resources


# Ignore internal development container files if any
.DS_Store
*.log